---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { filterPublicPosts, getCategoryStats, deduplicateByBaseSlugPreferLang, excerptFromBody, resolvePostThumbnail, slugify } from '../../lib/content';

const posts = filterPublicPosts(await getCollection('posts'));
const uniquePosts = deduplicateByBaseSlugPreferLang(posts, 'en');
const categories = getCategoryStats(posts);
---

<Layout title="Categories - GlobalFeed" description="Browse GlobalFeed by topic categories." lang="en">
	<section class="px-4 py-10 sm:px-6 lg:px-8">
		<div class="mb-8 max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Topics</p>
			<h1 class="mt-3 text-4xl font-black tracking-tight text-white sm:text-5xl">Browse by category</h1>
			<p class="mt-4 text-lg leading-8 text-slate-300">Find travel, food, city life, nature, and culture stories grouped into clean topic areas.</p>
		</div>

		<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
			{categories.map((category) => {
				const categoryPosts = uniquePosts.filter((post) => post.data.category === category.name).slice(0, 3);
				return (
					<section class="rounded-[2rem] border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
						<div class="flex items-start justify-between gap-3">
							<div>
								<h2 class="text-2xl font-bold text-white">{category.name}</h2>
								<p class="mt-2 text-sm text-slate-400">{category.count} article{category.count === 1 ? '' : 's'}</p>
							</div>
							<a href={`/categories/${category.slug}/`} class="rounded-full border border-white/10 bg-slate-950/70 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:text-cyan-200">Open</a>
						</div>

						<div class="mt-5 space-y-3">
			{categoryPosts.map((post) => {
				const thumb = resolvePostThumbnail(post);
				return (
					<a href={`/posts/${post.slug}/`} class="group block rounded-2xl border border-white/10 bg-slate-950/60 p-4 transition hover:border-cyan-400/25 hover:bg-slate-950/80">
						<div class="flex items-center gap-3">
							<div class="h-16 w-16 shrink-0 overflow-hidden rounded-2xl bg-slate-900">
								{thumb ? (
									<img src={thumb} alt={post.data.title} loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
								) : (
									<div class="grid h-full w-full place-items-center text-xs text-slate-500">No cover</div>
								)}
							</div>
							<div class="min-w-0">
								<h3 class="truncate text-sm font-semibold text-white transition group-hover:text-cyan-300">{post.data.title}</h3>
								<p class="mt-1 line-clamp-2 text-xs leading-5 text-slate-400">{excerptFromBody(post.body, 90)}</p>
							</div>
						</div>
					</a>
				);
			})}
						</div>
					</section>
				);
			})}
		</div>
	</section>
</Layout>
