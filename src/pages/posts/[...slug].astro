---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
	buildAbsolutePostUrl,
	filterPublicPosts,
	deduplicateByBaseSlug,
	filterPostsByCategory,
	filterPostsByTag,
	getBaseSlug,
	getShareLinks,
	getCategoryStats,
	slugify,
	sortLatest,
} from '../../lib/content';

export async function getStaticPaths() {
	const posts = filterPublicPosts(await getCollection('posts'));
	return posts.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allPosts = filterPublicPosts(await getCollection('posts'));
const uniquePosts = deduplicateByBaseSlug(sortLatest(allPosts));

const LANG_NAMES = { en: 'English', es: 'Español', fr: 'Français', de: 'Deutsch', ja: '日本語' };
const LANG_EMOJI = { en: '🇬🇧', es: '🇪🇸', fr: '🇫🇷', de: '🇩🇪', ja: '🇯🇵' };

const baseSlug = getBaseSlug(entry.slug);
const translations = allPosts.filter((p) => {
	const s = getBaseSlug(p.slug);
	return s === baseSlug && p.slug !== entry.slug;
});

const currentLang = Object.keys(LANG_NAMES).find((l) => entry.slug.endsWith(`-${l}`)) || 'zh';
const publishDate = entry.data.date ? new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const canonicalUrl = buildAbsolutePostUrl(entry.slug);
const shareLinks = getShareLinks(canonicalUrl, entry.data.title);
const popularCategories = getCategoryStats(allPosts).slice(0, 6);
const primaryTag = entry.data.tags?.[0] || null;
const tagSeriesPosts = primaryTag
	? filterPostsByTag(allPosts, primaryTag).filter((post) => post.slug !== entry.slug).slice(0, 3)
	: [];

const sameCategoryPosts = filterPostsByCategory(allPosts, entry.data.category)
	.filter((post) => post.slug !== entry.slug)
	.slice(0, 3);

const relatedPosts = [...sameCategoryPosts]
	.sort((a, b) => {
		const aScore = (a.data.tags || []).filter((tag) => entry.data.tags.includes(tag)).length;
		const bScore = (b.data.tags || []).filter((tag) => entry.data.tags.includes(tag)).length;
		return bScore - aScore || b.data.date.valueOf() - a.data.date.valueOf();
	})
	.slice(0, 3);

const currentIndex = uniquePosts.findIndex((post) => getBaseSlug(post.slug) === baseSlug);
const newerPost = currentIndex > 0 ? uniquePosts[currentIndex - 1] : null;
const olderPost = currentIndex >= 0 && currentIndex < uniquePosts.length - 1 ? uniquePosts[currentIndex + 1] : null;
---

<Layout title={`${entry.data.title} - GlobalFeed`} description={entry.data.title} lang={currentLang} canonical={canonicalUrl} alternates={[{ lang: currentLang, href: canonicalUrl }, ...translations.map((t) => ({ lang: Object.keys(LANG_NAMES).find((l) => t.slug.endsWith(`-${l}`)) || 'zh', href: buildAbsolutePostUrl(t.slug) }))]} ogImage={entry.data.cover_image || undefined} ogType="article">
	<article class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
		<div class="mb-8 flex flex-wrap items-center justify-center gap-2 text-sm">
			{translations.length > 0 && (
				<div class="flex flex-wrap justify-center gap-2">
					{translations.map((t) => {
						const tLang = Object.keys(LANG_NAMES).find((l) => t.slug.endsWith(`-${l}`)) || 'zh';
						return (
							<a href={`/posts/${t.slug}/`} class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-xs text-slate-300 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-200">
								{LANG_EMOJI[tLang]} {LANG_NAMES[tLang] || tLang.toUpperCase()}
							</a>
						);
					})}
				</div>
			)}
		</div>

		<header class="rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/20 backdrop-blur-xl sm:p-8">
			<div class="flex flex-wrap items-center gap-3 text-xs text-slate-400">
				<a href={`/categories/${slugify(entry.data.category)}/`} class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1.5 font-semibold text-cyan-200 transition hover:bg-cyan-400/15">{entry.data.category}</a>
				<span>{publishDate}</span>
				<span class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-slate-300">{LANG_EMOJI[currentLang] || '🌐'} {LANG_NAMES[currentLang] || currentLang.toUpperCase()}</span>
			</div>

			<h1 class="mt-5 text-4xl font-black tracking-tight text-white sm:text-5xl leading-tight">{entry.data.title}</h1>
			<p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
				Read, share, and explore related stories through curated categories and tags.
			</p>

			<div class="mt-8 flex flex-wrap gap-3 border-t border-white/10 pt-6">
				<a href={shareLinks.x} target="_blank" rel="noreferrer" class="rounded-full border border-white/10 bg-slate-950/60 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:text-cyan-200">X</a>
				<a href={shareLinks.telegram} target="_blank" rel="noreferrer" class="rounded-full border border-white/10 bg-slate-950/60 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:text-cyan-200">Telegram</a>
				<a href={shareLinks.whatsapp} target="_blank" rel="noreferrer" class="rounded-full border border-white/10 bg-slate-950/60 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:text-cyan-200">WhatsApp</a>
				<a href={shareLinks.facebook} target="_blank" rel="noreferrer" class="rounded-full border border-white/10 bg-slate-950/60 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:text-cyan-200">Facebook</a>
				<a href={shareLinks.linkedin} target="_blank" rel="noreferrer" class="rounded-full border border-white/10 bg-slate-950/60 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:text-cyan-200">LinkedIn</a>
				<button id="copy-share-link" type="button" data-share-url={canonicalUrl} class="rounded-full border border-white/10 bg-white px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-cyan-100">Copy link</button>
			</div>
		</header>

		{entry.data.cover_image && entry.data.cover_image !== '' && (
			<div class="mt-8 overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900 shadow-2xl shadow-black/20">
				<img src={entry.data.cover_image} alt={entry.data.title} loading="eager" fetchpriority="high" decoding="async" class="w-full object-cover" />
			</div>
		)}

		<div class="mt-8 rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/20 backdrop-blur-xl sm:p-8">
			<div class="prose prose-invert max-w-none prose-lg prose-headings:text-white prose-p:text-slate-300 prose-a:text-cyan-300 prose-strong:text-white prose-img:rounded-2xl prose-img:border prose-img:border-white/10">
				<Content />
			</div>
	</div>

		<div class="mt-8 flex flex-wrap gap-2">
			{entry.data.tags.map((tag) => (
				<a href={`/tags/${slugify(tag)}/`} class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-300 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-200">#{tag}</a>
			))}
		</div>

		<section class="mt-10 rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/20 backdrop-blur-xl sm:p-8">
			<div class="mb-5 flex items-center justify-between gap-3">
				<div>
					<h2 class="text-2xl font-bold text-white">Tag navigation</h2>
					<p class="mt-1 text-sm text-slate-400">Explore articles that share the same tag and jump to tag pages.</p>
				</div>
				<a href="/tags/" class="text-sm text-cyan-300 transition hover:text-cyan-200">All tags →</a>
			</div>

			<div class="flex flex-wrap gap-2">
				{entry.data.tags.map((tag) => (
					<a href={`/tags/${slugify(tag)}/`} class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-300 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-200">#{tag}</a>
				))}
			</div>

			{primaryTag && tagSeriesPosts.length > 0 ? (
				<div class="mt-6 grid gap-4 md:grid-cols-3">
					{tagSeriesPosts.map((post) => (
						<a href={`/posts/${post.slug}/`} class="group overflow-hidden rounded-3xl border border-white/10 bg-slate-950/70 transition hover:-translate-y-1 hover:border-cyan-400/30">
							<div class="aspect-[4/3] overflow-hidden bg-slate-900">
								{post.data.cover_image ? (
									<img src={post.data.cover_image} alt={post.data.title} loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
								) : (
									<div class="flex h-full items-center justify-center text-sm text-slate-500">No cover</div>
								)}
							</div>
							<div class="space-y-3 p-4">
								<div class="flex items-center gap-2 text-xs text-slate-400">
									<span>#{primaryTag}</span>
									<span class="h-1 w-1 rounded-full bg-slate-600"></span>
									<span>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
								</div>
								<h3 class="text-base font-semibold leading-snug text-white transition group-hover:text-cyan-300">{post.data.title}</h3>
							</div>
						</a>
					))}
				</div>
			) : (
				<p class="mt-4 text-sm text-slate-500">No other posts found with this tag yet.</p>
			)}
		</section>

		<section class="mt-10 rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/20 backdrop-blur-xl sm:p-8">
			<div class="mb-5 flex items-center justify-between gap-3">
				<div>
					<h2 class="text-2xl font-bold text-white">Category navigation</h2>
					<p class="mt-1 text-sm text-slate-400">Jump to the article’s category or explore nearby topics.</p>
				</div>
				<a href="/categories/" class="text-sm text-cyan-300 transition hover:text-cyan-200">All categories →</a>
			</div>

			<div class="flex flex-wrap gap-2">
				<a href={`/categories/${slugify(entry.data.category)}/`} class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-200 transition hover:border-cyan-400/30 hover:bg-cyan-400/15">
					{entry.data.category}
				</a>
				{popularCategories.map((category) => (
					<a href={`/categories/${slugify(category.name)}/`} class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-300 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-200">
						{category.name}
						<span class="ml-2 text-xs text-slate-500">{category.count}</span>
					</a>
				))}
			</div>
		</section>

		{newerPost || olderPost ? (
			<section class="mt-10 grid gap-4 md:grid-cols-2">
				{newerPost ? (
					<a href={`/posts/${newerPost.slug}/`} class="group rounded-[2rem] border border-white/10 bg-white/5 p-5 backdrop-blur-xl transition hover:border-cyan-400/25 hover:bg-white/10">
						<div class="text-xs uppercase tracking-[0.25em] text-cyan-300">Newer</div>
						<h2 class="mt-2 text-lg font-semibold text-white transition group-hover:text-cyan-300">{newerPost.data.title}</h2>
						<p class="mt-2 text-sm text-slate-400">Jump to the more recent article in this topic series.</p>
					</a>
				) : (
					<div class="rounded-[2rem] border border-white/10 bg-white/5 p-5 text-sm text-slate-500 backdrop-blur-xl">This is the newest article in this series.</div>
				)}

				{olderPost ? (
					<a href={`/posts/${olderPost.slug}/`} class="group rounded-[2rem] border border-white/10 bg-white/5 p-5 backdrop-blur-xl transition hover:border-cyan-400/25 hover:bg-white/10 md:text-right">
						<div class="text-xs uppercase tracking-[0.25em] text-cyan-300">Older</div>
						<h2 class="mt-2 text-lg font-semibold text-white transition group-hover:text-cyan-300">{olderPost.data.title}</h2>
						<p class="mt-2 text-sm text-slate-400">Continue to the previous article in this series.</p>
					</a>
				) : (
					<div class="rounded-[2rem] border border-white/10 bg-white/5 p-5 text-sm text-slate-500 backdrop-blur-xl">This is the oldest article in this series.</div>
				)}
			</section>
		) : null}

		{relatedPosts.length > 0 && (
			<section class="mt-10 rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/20 backdrop-blur-xl sm:p-8">
				<div class="mb-5 flex items-center justify-between gap-3">
					<div>
						<h2 class="text-2xl font-bold text-white">Related stories</h2>
						<p class="mt-1 text-sm text-slate-400">More articles from the same category and nearby topics.</p>
					</div>
					<a href={`/categories/${slugify(entry.data.category)}/`} class="text-sm text-cyan-300 transition hover:text-cyan-200">View category →</a>
				</div>

				<div class="grid gap-4 md:grid-cols-3">
					{relatedPosts.map((post) => (
						<a href={`/posts/${post.slug}/`} class="group overflow-hidden rounded-3xl border border-white/10 bg-slate-950/70 transition hover:-translate-y-1 hover:border-cyan-400/30">
							<div class="aspect-[4/3] overflow-hidden bg-slate-900">
								{post.data.cover_image ? (
									<img src={post.data.cover_image} alt={post.data.title} loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
								) : (
									<div class="flex h-full items-center justify-center text-sm text-slate-500">No cover</div>
								)}
							</div>
							<div class="space-y-3 p-4">
								<div class="flex items-center gap-2 text-xs text-slate-400">
									<span>{post.data.category}</span>
									<span class="h-1 w-1 rounded-full bg-slate-600"></span>
									<span>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
								</div>
								<h3 class="text-base font-semibold leading-snug text-white transition group-hover:text-cyan-300">{post.data.title}</h3>
							</div>
						</a>
					))}
				</div>
			</section>
		)}
	</article>

	<script is:inline>
		const copyButton = document.getElementById('copy-share-link');
		if (copyButton) {
			copyButton.addEventListener('click', async () => {
				const shareUrl = copyButton.getAttribute('data-share-url') || window.location.href;
				try {
					await navigator.clipboard.writeText(shareUrl);
					copyButton.textContent = 'Copied';
					setTimeout(() => {
						copyButton.textContent = 'Copy link';
					}, 1600);
				} catch (error) {
					console.error(error);
					copyButton.textContent = 'Copy failed';
					setTimeout(() => {
						copyButton.textContent = 'Copy link';
					}, 1600);
				}
			});
		}
	</script>
</Layout>

<style is:global>
	.prose img {
		width: 100%;
		margin-top: 2rem;
		margin-bottom: 2rem;
	}
</style>


