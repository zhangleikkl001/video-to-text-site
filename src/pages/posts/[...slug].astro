---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	return posts.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allPosts = await getCollection('posts');

// 语言切换器：找到同一篇文章的其他语言版本
const LANG_SUFFIXES = ["-en", "-es", "-fr", "-de", "-ja"];
const LANG_NAMES = { "en": "English", "es": "Español", "fr": "Français", "de": "Deutsch", "ja": "日本語" };
const LANG_EMOJI = { "en": "🇬🇧", "es": "🇪🇸", "fr": "🇫🇷", "de": "🇩🇪", "ja": "🇯🇵" };

// 解析当前slug找到base
function getBaseSlug(slug) {
	for (const suffix of LANG_SUFFIXES) {
		if (slug.endsWith(suffix)) return slug.slice(0, -suffix.length);
	}
	return slug;
}
const baseSlug = getBaseSlug(entry.slug);

// 找到所有语言版本
const translations = allPosts.filter(p => {
	const s = getBaseSlug(p.slug);
	return s === baseSlug && p.slug !== entry.slug;
});

// 当前语言
const currentLang = Object.keys(LANG_NAMES).find(l => entry.slug.endsWith(`-${l}`)) || "zh";
const publishDate = entry.data.date ? new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
---

<Layout title={`${entry.data.title} - GlobalFeed`}>
	<article class="py-10 max-w-screen-md mx-auto px-4">
		<!-- 语言切换器 -->
		{translations.length > 1 && (
		<div class="flex flex-wrap gap-2 mb-8 justify-center">
			<span class="text-sm text-gray-400 mr-1">🌐 Languages:</span>
			{translations.map(t => {
				const tLang = Object.keys(LANG_NAMES).find(l => t.slug.endsWith(`-${l}`)) || "zh";
				return (
					<a href={`/posts/${t.slug}/`}
						class="px-3 py-1 text-xs rounded-full border border-gray-700 text-gray-300 hover:border-blue-500 hover:text-blue-400 transition-all">
						{LANG_EMOJI[tLang]} {LANG_NAMES[tLang] || tLang.toUpperCase()}
					</a>
				);
			})}
		</div>
		)}

		<header class="mb-10 text-center">
			<div class="flex justify-center items-center gap-3 mb-4">
				<span class="px-3 py-1 bg-blue-500/20 text-blue-400 text-sm font-semibold rounded-full uppercase">
					{entry.data.category}
				</span>
				<span class="text-gray-500">{publishDate}</span>
			</div>
			<h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-6">
				{entry.data.title}
			</h1>
			<!-- 语言标签 -->
			<span class="inline-block px-2 py-0.5 bg-gray-800 text-gray-400 text-xs rounded">
				{LANG_EMOJI[currentLang] || '🌐'} {LANG_NAMES[currentLang] || currentLang.toUpperCase()}
			</span>
		</header>

		{entry.data.cover_image && entry.data.cover_image != "" && (
		<div class="rounded-3xl overflow-hidden mb-12 shadow-2xl shadow-blue-500/10">
			<img src={entry.data.cover_image} alt={entry.data.title} class="w-full object-cover" />
		</div>
		)}

		<div class="prose prose-invert prose-lg max-w-none prose-headings:text-white prose-p:text-gray-300 prose-img:rounded-2xl prose-a:text-blue-400">
			<Content />
		</div>
		
		<div class="mt-16 pt-8 border-t border-gray-800">
			<!-- 标签 -->
			<div class="flex flex-wrap gap-2 mb-4">
				{entry.data.tags.map(tag => (
					<span class="text-sm text-gray-500 font-mono italic">#{tag}</span>
				))}
			</div>
			<!-- 来源链接 -->
			{entry.data.original_url && (
				<div class="text-sm text-gray-500">
					📎 Source: 
					<a href={entry.data.original_url} target="_blank" class="text-blue-400 hover:underline ml-1">
						{entry.data.source || "Original Article"} ↗
					</a>
				</div>
			)}
		</div>
	</article>
</Layout>

<style is:global>
	.prose img {
		width: 100%;
		margin-top: 2rem;
		margin-bottom: 2rem;
	}
</style>
