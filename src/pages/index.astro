---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="GlobalFeed - Discover China through AI">
	<div class="py-8 space-y-12">
		{sortedPosts.map((post) => (
			<article class="bg-gray-900 rounded-2xl overflow-hidden border border-gray-800 hover:border-blue-500/50 transition-all group">
				<a href={`/posts/${post.slug}`} class="block">
					<div class="aspect-video overflow-hidden">
						<img 
							src={post.data.cover_image} 
							alt={post.data.title}
							class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
						/>
					</div>
					<div class="p-6">
						<div class="flex items-center gap-2 mb-3">
							<span class="px-2 py-1 bg-blue-500/10 text-blue-400 text-xs font-medium rounded uppercase tracking-wider">
								{post.data.category}
							</span>
							<span class="text-gray-500 text-xs">
								{post.data.date.toLocaleDateString()}
							</span>
						</div>
						<h2 class="text-2xl font-bold text-white mb-3 group-hover:text-blue-400 transition-colors">
							{post.data.title}
						</h2>
						<p class="text-gray-400 line-clamp-2 mb-4">
							{post.body.substring(0, 150)}...
						</p>
						<div class="flex flex-wrap gap-2">
							{post.data.tags.map((tag) => (
								<span class="text-xs text-gray-500 font-mono italic">#{tag}</span>
							))}
						</div>
					</div>
				</a>
			</article>
		))}
	</div>
</Layout>
