---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { filterPublicPosts, getTagStats, deduplicateByBaseSlug, excerptFromBody, sortLatest, slugify } from '../../lib/content';

const posts = filterPublicPosts(await getCollection('posts'));
const uniquePosts = deduplicateByBaseSlug(sortLatest(posts));
const tags = getTagStats(posts);
---

<Layout title="Popular Tags - GlobalFeed" description="Browse GlobalFeed by popular tags." lang="en">
	<section class="px-4 py-10 sm:px-6 lg:px-8">
		<div class="mb-8 max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Topics</p>
			<h1 class="mt-3 text-4xl font-black tracking-tight text-white sm:text-5xl">Popular tags</h1>
			<p class="mt-4 text-lg leading-8 text-slate-300">Dive into the themes readers engage with most often — food, scenery, city life, culture, and more.</p>
		</div>

		<div class="flex flex-wrap gap-3">
			{tags.map((tag) => (
				<a href={`/tags/${tag.slug}/`} class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-200">
					<span>#{tag.name}</span>
					<span class="text-xs text-slate-400">{tag.count}</span>
				</a>
			))}
		</div>

		<div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
			{tags.map((tag) => {
				const tagPosts = uniquePosts.filter((post) => (post.data.tags || []).includes(tag.name)).slice(0, 3);
				return (
					<section class="rounded-[2rem] border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
						<div class="flex items-start justify-between gap-3">
							<div>
								<h2 class="text-xl font-bold text-white">#{tag.name}</h2>
								<p class="mt-2 text-sm text-slate-400">{tag.count} article{tag.count === 1 ? '' : 's'}</p>
							</div>
							<a href={`/tags/${tag.slug}/`} class="rounded-full border border-white/10 bg-slate-950/70 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:text-cyan-200">Open</a>
						</div>

						<div class="mt-5 space-y-3">
							{tagPosts.map((post) => (
								<a href={`/posts/${post.slug}/`} class="group block rounded-2xl border border-white/10 bg-slate-950/60 p-4 transition hover:border-cyan-400/25 hover:bg-slate-950/80">
									<h3 class="text-sm font-semibold text-white transition group-hover:text-cyan-300">{post.data.title}</h3>
									<p class="mt-2 line-clamp-2 text-xs leading-5 text-slate-400">{excerptFromBody(post.body, 90)}</p>
								</a>
							))}
						</div>
					</section>
				);
			})}
		</div>
	</section>
</Layout>
