---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { filterPublicPosts, getCategoryStats, getLocalizedPostEntry, getTagStats, getTrendingPosts, excerptFromBody, resolvePostThumbnail } from '../lib/content';

const posts = filterPublicPosts(await getCollection('posts'));
const trendingPosts = getTrendingPosts(posts, 12).map((post) => getLocalizedPostEntry(posts, post.slug, 'en') || post);
const categories = getCategoryStats(posts).slice(0, 8);
const popularTags = getTagStats(posts).slice(0, 12);
---

<Layout title="Trending - GlobalFeed" description="See what is trending now on GlobalFeed." lang="en">
	<section class="px-4 py-10 sm:px-6 lg:px-8">
		<div class="max-w-4xl">
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">Trending</p>
			<h1 class="mt-3 text-4xl font-black tracking-tight text-white sm:text-5xl">Hot articles right now</h1>
			<p class="mt-4 text-lg leading-8 text-slate-300">
				A curated ranking based on freshness, topic density, and title strength — designed to surface the most engaging stories first.
			</p>
		</div>

		<div class="mt-8 grid gap-6 lg:grid-cols-[1.3fr_0.7fr]">
			<div class="space-y-4">
				{trendingPosts.map((post, index) => {
					const thumb = resolvePostThumbnail(post);
					return (
						<a href={`/posts/${post.slug}/`} class="group grid gap-4 rounded-[2rem] border border-white/10 bg-white/5 p-5 shadow-2xl shadow-black/20 backdrop-blur-xl transition hover:border-cyan-400/25 hover:bg-white/10 md:grid-cols-[220px_1fr] md:items-center">
							<div class="relative overflow-hidden rounded-2xl bg-slate-900 aspect-[16/10] md:aspect-auto md:h-32">
								{thumb ? (
									<img src={thumb} alt={post.data.title} loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
								) : (
									<div class="grid h-full w-full place-items-center text-xs text-slate-500">No cover</div>
								)}
								<div class="absolute left-3 top-3 rounded-full bg-black/60 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">#{index + 1}</div>
							</div>
							<div class="space-y-3">
								<div class="flex flex-wrap items-center gap-2 text-xs text-slate-400">
									<span class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2.5 py-1 text-cyan-200">{post.data.category}</span>
									<span>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
									<span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-slate-300">{post.slug.endsWith('-en') ? 'EN' : post.slug.endsWith('-es') ? 'ES' : post.slug.endsWith('-fr') ? 'FR' : post.slug.endsWith('-de') ? 'DE' : post.slug.endsWith('-ja') ? 'JA' : 'ZH'}</span>
								</div>
								<h2 class="text-2xl font-bold text-white transition group-hover:text-cyan-300">{post.data.title}</h2>
								<p class="text-sm leading-7 text-slate-400">{excerptFromBody(post.body, 180)}</p>
								<div class="flex flex-wrap gap-2 pt-1">
									{post.data.tags.slice(0, 5).map((tag) => (
										<span class="rounded-full bg-white/5 px-3 py-1 text-xs text-slate-300">#{tag}</span>
									))}
								</div>
							</div>
						</a>
					);
				})}
			</div>

			<aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
				<section class="rounded-[2rem] border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
					<div class="mb-4 flex items-center justify-between">
						<h2 class="text-lg font-semibold text-white">Popular tags</h2>
						<a href="/tags/" class="text-sm text-cyan-300 transition hover:text-cyan-200">View all</a>
					</div>
					<div class="flex flex-wrap gap-2">
						{popularTags.map((tag) => (
							<a href={`/search/?q=${encodeURIComponent(tag.name)}`} class="rounded-full border border-white/10 bg-slate-950/60 px-4 py-2 text-sm text-slate-300 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-200">#{tag.name}</a>
						))}
					</div>
				</section>

				<section class="rounded-[2rem] border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
					<div class="mb-4 flex items-center justify-between">
						<h2 class="text-lg font-semibold text-white">Top categories</h2>
						<a href="/categories/" class="text-sm text-cyan-300 transition hover:text-cyan-200">View all</a>
					</div>
					<div class="space-y-2">
						{categories.map((category) => (
							<a href={`/categories/${category.slug}/`} class="flex items-center justify-between rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-sm text-slate-200 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-200">
								<span>{category.name}</span>
								<span class="text-xs text-slate-400">{category.count}</span>
							</a>
						))}
					</div>
				</section>
			</aside>
		</div>
	</section>
</Layout>
